{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Community Reaction Added Event",
  "description": "Publicado pelo módulo community quando uma reação é adicionada/trocada num post.",
  "type": "object",
  "properties": {
    "tenant_id": { "type": "string" },
    "post_id": { "type": "string" },
    "user_id": { "type": "string" },
    "type": { "type": "string", "enum": ["like", "applaud", "laugh", "wow", "sad", "angry"] },
    "author_id": { "type": "string" }
  },
  "required": ["tenant_id", "post_id", "user_id", "type"]
}
