{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wallet Withdrawal Failed Event",
  "description": "Saque PIX da carteira falhou no trilho BaaS (reserva liberada, sem débito).",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "wallet_ref": {
      "type": "string"
    },
    "withdrawal_id": {
      "type": "string"
    },
    "amount_cents": {
      "type": "integer"
    },
    "fail_reason": {
      "type": "string"
    }
  },
  "required": [
    "tenant_id",
    "wallet_ref",
    "withdrawal_id",
    "amount_cents"
  ]
}
