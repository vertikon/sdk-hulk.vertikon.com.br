{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Subscription Created Event",
  "description": "Publicado pelo subscription-hub quando uma assinatura é criada.",
  "type": "object",
  "properties": {
    "subscription_id": { "type": "string" },
    "customer_id": { "type": "string" },
    "plan_id": { "type": "string" },
    "status": { "type": "string", "enum": ["TRIALING", "ACTIVE", "PAST_DUE", "UNPAID", "CANCELED", "PAUSED"] },
    "created_at": { "type": "string", "format": "date-time" },
    "period_end": { "type": "string", "format": "date-time" }
  },
  "required": ["subscription_id", "customer_id", "plan_id", "status", "created_at"]
}
