{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gamification Level Up Event",
  "description": "Publicado pelo módulo gamification quando um usuário sobe de nível.",
  "type": "object",
  "properties": {
    "user_id": { "type": "string" },
    "old_level": { "type": "integer", "minimum": 1 },
    "new_level": { "type": "integer", "minimum": 1 },
    "xp_total": { "type": "integer", "minimum": 0 },
    "at": { "type": "string", "format": "date-time" }
  },
  "required": ["user_id", "new_level"]
}
